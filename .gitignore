# ML Models - ignore all by default, then explicitly keep the active ones
ML/models/

# Keep active parts vision model (used by hybrid_parts_service.py on port 8007)
# Backend calls port 8007 -> hybrid_parts_service.py -> loads these two files
!ML/models/parts_classifier.h5
!ML/models/class_indices.json

# Keep active fault diagnosis models (used by fault_diagnosis_system.py on port 8008)
!ML/models/fault_diagnosis_model.pkl
!ML/models/symptom_vectorizer.pkl

# Keep cashflow category mapping (used by categorized_cashflow_service.py)
# Note: cashflow_predictor.py trains on-the-fly from DB - no saved model needed
!ML/models/category_mapping.json

# Keep these essential ML service files
!ML/cashflow_service.py
!ML/cashflow_predictor.py
!ML/analytics_service.py
!ML/categorized_cashflow_service.py
!ML/auto_parts_business_intelligence.py
!ML/parts_vision_service.py
!ML/fault_diagnosis_system.py
!ML/advanced_fault_diagnosis.py
!ML/hybrid_parts_service.py
!ML/enhanced_parts_vision_service.py
!ML/filtered_parts_vision.py
!ML/requirements.txt
!ML/requirements_vision.txt
!ML/.env.example

