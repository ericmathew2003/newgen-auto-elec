# ── Local Development ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=newgen
DB_USER=postgres
DB_PASSWORD=your_password

# ── Hosted (Render) ───────────────────────────────────────────────────────────
# Use DATABASE_URL instead of individual vars when deploying to Render/Neon/Supabase
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_PORT=8001

# ── CORS ──────────────────────────────────────────────────────────────────────
VERCEL_FRONTEND_URL=https://newgen-auto-frontend.vercel.app
VERCEL_BACKEND_URL=https://newgen-auto-elec.vercel.app
